# Copy to host/.env (gitignored) and set your robot's address.
# Used by `make timesync` (auto-run by make slam / nav2 / explore) to sync the
# robot clock to this host so tf2/SLAM don't drop the robot's messages.
# You can also just `export ROBOT=...` in your shell instead of this file.
ROBOT=192.0.2.10
