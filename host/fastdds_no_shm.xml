<?xml version="1.0" encoding="UTF-8"?>
<!-- Fast-DDS (the container's rmw) profile: UDP only, no shared-memory transport.
     ros2dreame on the robot uses RustDDS; SHM is same-host only, so forcing UDP
     makes the container reliably talk to the robot over the network (and to any
     other host). Referenced via FASTRTPS_DEFAULT_PROFILES_FILE. -->
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <profiles>
    <transport_descriptors>
      <transport_descriptor>
        <transport_id>udp_transport</transport_id>
        <type>UDPv4</type>
      </transport_descriptor>
    </transport_descriptors>
    <participant profile_name="udp_only" is_default_profile="true">
      <rtps>
        <useBuiltinTransports>false</useBuiltinTransports>
        <userTransports>
          <transport_id>udp_transport</transport_id>
        </userTransports>
      </rtps>
    </participant>
  </profiles>
</dds>
